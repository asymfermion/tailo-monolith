{
  "expo": {
    "name": "Tailo",
    "slug": "tailo",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/brand/app-icon.png",
    "userInterfaceStyle": "light",
    "scheme": "tailo",
    "ios": {
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "bundleIdentifier": "com.mtxforge.tailo",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "Tailo scans your recent photos to find pet moments for your timeline.",
        "NSPhotoLibraryAddUsageDescription": "Tailo can save photos you capture in the app to your photo library.",
        "NSCameraUsageDescription": "Tailo uses the camera so you can capture new pet moments.",
        "NSMicrophoneUsageDescription": "Tailo may use the microphone when recording video moments."
      },
      "buildNumber": "2"
    },
    "android": {
      "package": "com.mtxforge.tailo",
      "adaptiveIcon": {
        "foregroundImage": "./assets/brand/app-icon.png",
        "backgroundColor": "#FBF7F1"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/brand/favicon.png"
    },
    "plugins": [
      [
        "expo-media-library",
        {
          "photosPermission": "Tailo scans your recent photos to find pet moments for your timeline.",
          "savePhotosPermission": "Tailo can save photos you capture in the app to your photo library.",
          "isAccessMediaLocationEnabled": true,
          "granularPermissions": ["photo"]
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Tailo uses the camera so you can capture new pet moments.",
          "microphonePermission": "Tailo may use the microphone when recording video moments.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/brand/app-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#FBF7F1"
        }
      ],
      "expo-secure-store",
      "expo-sqlite",
      "expo-apple-authentication",
      "expo-font",
      "expo-web-browser",
      "expo-image",
      "expo-status-bar",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.4"
          }
        }
      ]
    ],
    "experiments": {
      "tsconfigPaths": true,
      "autolinkingModuleResolution": true
    },
    "extra": {
      "eas": {
        "projectId": "9e7c7c1d-583b-47d4-a1cd-463d5029c28a"
      }
    },
    "owner": "brendan.zj"
  }
}
