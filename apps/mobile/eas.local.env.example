# Copy to eas.local.env (gitignored). Used by `npm run eas:ios` for Apple + submit automation.
#
# EXPO_* vars are read directly by eas-cli. Shorter APPLE_* aliases also work when the
# matching EXPO_* var is omitted (see optional section at the bottom).

# --- Submit ---
# ascAppId + appleTeamId live in eas.json (submit.production.ios).
# EXPO_APPLE_ID below is used for Apple account email on submit.
# Optional override if eas.json is not updated yet:
# ASC_APP_ID=1234567890

# --- Apple Developer (skips team/provider/login prompts on build & credentials) ---
# EXPO_APPLE_ID=you@example.com
# EXPO_APPLE_TEAM_ID=ABCDE12345
# EXPO_APPLE_PROVIDER_ID=123456789
# EXPO_APPLE_TEAM_TYPE=INDIVIDUAL

# --- Submit without prompts (optional) ---
# https://appleid.apple.com → Sign-In and Security → App-Specific Passwords
# EXPO_APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx

# --- Force non-interactive EAS (optional) ---
# EAS_NON_INTERACTIVE=1

# --- App Store Connect API key (CI / credential repair; keep .p8 out of git) ---
# EXPO_ASC_API_KEY_PATH=./AuthKey_XXXXXXXXXX.p8
# EXPO_ASC_KEY_ID=XXXXXXXXXX
# EXPO_ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# --- Optional aliases (only if matching EXPO_* line above is omitted) ---
# APPLE_ID=you@example.com
# APPLE_TEAM_ID=ABCDE12345
# APPLE_PROVIDER_ID=123456789
# APPLE_TEAM_TYPE=INDIVIDUAL
# APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx
