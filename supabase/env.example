# Copy to supabase/.env.local (gitignored). Used by Supabase CLI — never commit secrets.
#
# Dev project ref: sgxtyxvithlmuuofkzlk
# Dashboard: https://supabase.com/dashboard/project/sgxtyxvithlmuuofkzlk

# Required for verify:supabase and some CLI DB commands. Get from Dashboard → Connect → URI.
# Replace [YOUR-PASSWORD] with the database password (Project Settings → Database).
#
# Direct (IPv6): Database → Connection string → URI
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.sgxtyxvithlmuuofkzlk.supabase.co:5432/postgres
#
# IPv4-only? Use Session pooler instead (Connection pooling → Session mode) and comment the line above:
# DATABASE_URL=postgresql://postgres.sgxtyxvithlmuuofkzlk:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# --- Edge Function secrets (set via CLI, NOT in this file) ---
# See supabase/GCP_VERTEX_SETUP.md
#   npx supabase secrets set AI_PROVIDER=vertex
#   npx supabase secrets set GCP_PROJECT_ID=...
#   npx supabase secrets set GCP_VERTEX_REGION=us-central1
#   npx supabase secrets set GCP_VERTEX_MODEL=gemini-2.5-flash
#   npx supabase secrets set GCP_SERVICE_ACCOUNT_JSON="$(jq -c . < key.json)"
